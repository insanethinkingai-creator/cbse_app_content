    {
      "id": "g7_m7_q1",
      "text": "Ratio of 3 km to 300 m is:",
      "options": ["1:10", "10:1", "1:100", "100:1"],
      "correctIndex": 1,
      "explanation": "3 km = 3000 m. Ratio = 3000 / 300 = 10 / 1.",
      "frequencyRating": 5
    },
    {
      "id": "g7_m7_q2",
      "text": "A ratio has ________ unit(s).",
