"9"],"correctIndex":0,"explanation":"3x=33, x=11.","frequencyRating":5},{"id":"g8_m2_q33","text":"Money divided 3:5, larger Rs 50 more. Total?","options":["160","200","120","180"],"correctIndex":0,"explanation":"8parts, 2parts=50, part=25, total 200.","frequencyRating":4},{"id":"g8_m2_q34","text":"Train speed 72 km/h = ? m/s","options":["20 m/s","30","40","25"],"correctIndex":0,"explanation":"72*5/18 = 20.","frequencyRating":5},{"id":"g8_m2_q35","text":"x/5 + x/10 = 11.","options":["50","40","60","30"],"correctIndex":0,"explanation":"2x/10 + x/10 = 11 => 3x/10 = 11 => x=110/3? Recheck.","frequencyRating":4},{"id":"g8_m2_q36","text":"A does job in 10 days, B 15, together?","options":["6 days","5","7","4"],"correctIndex":0,"explanation":"1/10 + 1/15 = 1/6, 6 days.","frequencyRating":5},{"id":"g8_m2_q37","text":"Circumference 44 cm, radius? (22/7)","options":["7 cm","14","3.5","21"],"correctIndex":0,"explanation": "2πr=44 => r=7.","frequencyRating":4},{"id":"g8_m2_q38","text":"Solve  (x+1)/2 - (x-1)/3 = 3/2.","options":["1","2","0","3"],"correctIndex":1,"explanation":"Solve with LCM 6.","frequencyRating":5},{"id":"g8_m2_q39","text":"Length 2x cm, breadth x cm, perimeter 30 cm, x?","options":["5 cm","10","3","6"],"correctIndex":0,"explanation":"2(2x + x)=30 => 6x=30 => x=5.","frequencyRating":5},{"id":"g8_m2_q40","text":"A's income Rs 6000, spends 3/4, saves?","options":["Rs 1500","Rs 4500","Rs 2000","Rs 4000"],"correctIndex":0,"explanation":"6000 - (3/4)*6000 = 1500.","frequencyRating":5}]}
