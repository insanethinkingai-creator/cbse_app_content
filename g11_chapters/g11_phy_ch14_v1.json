    { "id": "g11_p14_q11", "text": "Sound travels fastest in:", "options": ["Solids", "Liquids", "Gases", "Vacuum"], "correctIndex": 0, "explanation": "Due to high elasticity of solids.", "frequencyRating": 5 },
    { "id": "g11_p14_q12", "text": "Relation between velocity, frequency and wavelength is:", "options": ["v = νλ", "v = ν/λ", "v = λ/ν", "v = ν²λ"], "correctIndex": 0, "explanation": "Basic wave relation.", "frequencyRating": 5 },
    { "id": "g11_p14_q13", "text": "At a node in a stationary wave:", "options": ["Displacement is max", "Displacement is zero", "Pressure change is zero", "None"], "correctIndex": 1, "explanation": "Nodes are points of permanent rest.", "frequencyRating": 5 },
    { "id": "g11_p14_q14", "text": "Closed organ pipes produce:", "options": ["All harmonics", "Only even harmonics", "Only odd harmonics", "None"], "correctIndex": 2, "explanation": "Ratio of frequencies is 1:3:5...", "frequencyRating": 5 },
    { "id": "g11_p14_q15", "text": "Open organ pipes produce:", "options": ["All harmonics", "Only even harmonics", "Only odd harmonics", "None"], "correctIndex": 0, "explanation": "Ratio is 1:2:3...", "frequencyRating": 5 },
    { "id": "g11_p14_q16", "text": "Speed of sound in air increases with:", "options": ["Humidity", "Temperature", "Both", "Pressure"], "correctIndex": 2, "explanation": "Pressure has no effect on speed of sound if T is constant.", "frequencyRating": 5 },
    { "id": "g11_p14_q17", "text": "Wave number is defined as:", "options": ["1/λ", "2π/λ", "ν/v", "λ/T"], "correctIndex": 1, "explanation": "Also called propagation constant k.", "frequencyRating": 4 },
    { "id": "g11_p14_q18", "text": "Energy is not transferred by:", "options": ["Progressive waves", "Stationary waves", "Electromagnetic waves", "Mechanical waves"], "correctIndex": 1, "explanation": "Energy is trapped between nodes.", "frequencyRating": 5 },
    { "id": "g11_p14_q19", "text": "Intensity of wave is proportional to:", "options": ["Amplitude", "Amplitude squared", "Frequency", "Wavelength"], "correctIndex": 1, "explanation": "I ∝ A².", "frequencyRating": 5 },
    { "id": "g11_p14_q20", "text": "Ultrasonic waves have frequency:", "options": ["< 20 Hz", "20 - 20,000 Hz", "> 20,000 Hz", "Infinite"], "correctIndex": 2, "explanation": "Above human hearing range.", "frequencyRating": 4 },
    { "id": "g11_p14_q21", "text": "Which property of sound changes when it enters from air to water?", "options": ["Frequency", "Wavelength", "Speed", "Both B and C"], "correctIndex": 3, "explanation": "Frequency depends only on the source.", "frequencyRating": 4 },
    { "id": "g11_p14_q22", "text": "Equation of a progressive wave is:", "options": ["y = A sin(kx - ωt)", "y = A sin(kx) cos(ωt)", "y = mx + c", "y = x²"], "correctIndex": 0, "explanation": "Represents a wave moving in +x direction.", "frequencyRating": 5 },
    { "id": "g11_p14_q23", "text": "In a string, the fundamental frequency is also called:", "options": ["1st Harmonic", "1st Overtone", "2nd Harmonic", "Resonance"], "correctIndex": 0, "explanation": "Lowest possible frequency.", "frequencyRating": 4 },
    { "id": "g11_p14_q24", "text": "Pitch of sound depends on:", "options": ["Amplitude", "Frequency", "Speed", "Wavelength"], "correctIndex": 1, "explanation": "High frequency means high pitch.", "frequencyRating": 5 },
    { "id": "g11_p14_q25", "text": "Loudness of sound depends on:", "options": ["Amplitude", "Frequency", "Pitch", "Wavelength"], "correctIndex": 0, "explanation": "Larger amplitude means louder sound.", "frequencyRating": 5 },
    { "id": "g11_p14_q26", "text": "Newton's formula for speed of sound in air is:", "options": ["sqrt(P/ρ)", "sqrt(γP/ρ)", "sqrt(E/ρ)", "P/ρ"], "correctIndex": 0, "explanation": "Corrected later by Laplace.", "frequencyRating": 4 },
    { "id": "g11_p14_q27", "text": "Maximum number of beats a human ear can distinguish is:", "options": ["10 per second", "2 per second", "50 per second", "1 per second"], "correctIndex": 0, "explanation": "Persistence of hearing is 0.1s.", "frequencyRating": 3 },
    { "id": "g11_p14_q28", "text": "If source is moving towards a stationary observer, apparent frequency:", "options": ["Increases", "Decreases", "Same", "Zero"], "correctIndex": 0, "explanation": "Wavefronts are bunched together.", "frequencyRating": 5 },
    { "id": "g11_p14_q29", "text": "A pulse is a _____ wave.", "options": ["Continuous", "Non-periodic", "Stationary", "None"], "correctIndex": 1, "explanation": "A single disturbance of short duration.", "frequencyRating": 3 },
    { "id": "g11_p14_q30", "text": "Points of maximum displacement in stationary waves are:", "options": ["Nodes", "Antinodes", "Origins", "Extreme"], "correctIndex": 1, "explanation": "Opposite of nodes.", "frequencyRating": 5 },
    { "id": "g11_p14_q31", "text": "Ratio of intensities of two waves is 9:1. Ratio of amplitudes is:", "options": ["9:1", "81:1", "3:1", "1:3"], "correctIndex": 2, "explanation": "I ∝ A² => A ∝ sqrt(I).", "frequencyRating": 4 },
    { "id": "g11_p14_q32", "text": "Phase difference of π corresponds to path difference of:", "options": ["λ", "λ/2", "λ/4", "2λ"], "correctIndex": 1, "explanation": "Δφ = (2π/λ)Δx.", "frequencyRating": 5 },
    { "id": "g11_p14_q33", "text": "Echo is produced due to:", "options": ["Refraction", "Reflection", "Diffraction", "Interference"], "correctIndex": 1, "explanation": "Bouncing of sound from a surface.", "frequencyRating": 4 },
    { "id": "g11_p14_q34", "text": "Minimum distance to hear an echo is approx:", "options": ["17 m", "34 m", "10 m", "100 m"], "correctIndex": 0, "explanation": "Based on 0.1s persistence of hearing.", "frequencyRating": 4 },
    { "id": "g11_p14_q35", "text": "Shock waves are produced by:", "options": ["Subsonic objects", "Supersonic objects", "Ultrasonic objects", "Stationary objects"], "correctIndex": 1, "explanation": "Objects moving faster than the speed of sound.", "frequencyRating": 3 },
    { "id": "g11_p14_q36", "text": "The 1st overtone of a closed pipe is:", "options": ["2nd harmonic", "3rd harmonic", "4th harmonic", "Fundamental"], "correctIndex": 1, "explanation": "Frequency is 3 * fundamental.", "frequencyRating": 4 },
    { "id": "g11_p14_q37", "text": "Tuning forks are used to:", "options": ["Produce beats", "Determine frequency", "Tune instruments", "All of these"], "correctIndex": 3, "explanation": "Standard laboratory tools.", "frequencyRating": 4 },
    { "id": "g11_p14_q38", "text": "SONAR uses _____ waves.", "options": ["Infrared", "Ultrasonic", "Infrasonic", "Visible"], "correctIndex": 1, "explanation": "For underwater detection.", "frequencyRating": 4 },
    { "id": "g11_p14_q39", "text": "A wave is a means of transferring _____ without transferring _____.", "options": ["Mass, Energy", "Energy, Mass", "Momentum, Energy", "Charge, Mass"], "correctIndex": 1, "explanation": "Fundamental property of waves.", "frequencyRating": 5 },
    { "id": "g11_p14_q40", "text": "Wave velocity in a gas depends on:", "options": ["T only", "T and M", "T and P", "P and M"], "correctIndex": 1, "explanation": "v = sqrt(γRT/M).", "frequencyRating": 4 }
